rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Pharmacies: only authenticated users ───
    match /pharmacies/{pharmacyId} {
      allow read, write: if request.auth != null;

      // Medicines subcollection
      match /medicines/{medicineId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null;
        allow delete: if request.auth != null && request.auth.token.role == "owner";
      }

      // Invoices subcollection
      match /invoices/{invoiceId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && request.auth.token.role == "owner";
      }

      // Staff subcollection
      match /staff/{staffId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.auth.token.role == "owner";
        allow delete: if request.auth != null && request.auth.token.role == "owner";
      }

      // Distributors subcollection
      match /distributors/{distId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
