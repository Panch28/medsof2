rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Flat rules — no nesting, no functions, just inline exists() checks

    match /pharmacies/{pharmacyId}/staff/{staffId} {
      allow read: if request.auth != null
                  && exists(/databases/$(database)/documents/pharmacies/$(pharmacyId)/staff/$(request.auth.uid));
      allow create: if request.auth != null
                    && staffId == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
                    && exists(/databases/$(database)/documents/pharmacies/$(pharmacyId)/staff/$(request.auth.uid));
      allow delete: if request.auth != null
                    && exists(/databases/$(database)/documents/pharmacies/$(pharmacyId)/staff/$(request.auth.uid));
    }

    match /pharmacies/{pharmacyId}/invoices/{invoiceId} {
      allow read: if request.auth != null
                  && exists(/databases/$(database)/documents/pharmacies/$(pharmacyId)/staff/$(request.auth.uid));
      allow create: if request.auth != null
                    && exists(/databases/$(database)/documents/pharmacies/$(pharmacyId)/staff/$(request.auth.uid));
      allow update: if request.auth != null
                    && exists(/databases/$(database)/documents/pharmacies/$(pharmacyId)/staff/$(request.auth.uid));
      allow delete: if request.auth != null
                    && exists(/databases/$(database)/documents/pharmacies/$(pharmacyId)/staff/$(request.auth.uid));
    }

    match /pharmacies/{pharmacyId}/medicines/{medicineId} {
      allow read: if request.auth != null
                  && exists(/databases/$(database)/documents/pharmacies/$(pharmacyId)/staff/$(request.auth.uid));
      allow create: if request.auth != null
                    && exists(/databases/$(database)/documents/pharmacies/$(pharmacyId)/staff/$(request.auth.uid));
      allow update: if request.auth != null
                    && exists(/databases/$(database)/documents/pharmacies/$(pharmacyId)/staff/$(request.auth.uid));
      allow delete: if request.auth != null
                    && exists(/databases/$(database)/documents/pharmacies/$(pharmacyId)/staff/$(request.auth.uid));
    }

    match /pharmacies/{pharmacyId}/distributors/{distId} {
      allow read, write: if request.auth != null
                         && exists(/databases/$(database)/documents/pharmacies/$(pharmacyId)/staff/$(request.auth.uid));
    }
  }
}
